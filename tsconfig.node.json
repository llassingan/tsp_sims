// Node-side TypeScript configuration for the TSP Simulator POC.
// Covers build/tooling config files (vite, vitest, playwright, tailwind, postcss, eslint)
// and Playwright E2E test specs.
//
// Uses the ES2023 standard library (includes `Array.prototype.toSorted`, `findLast`,
// and other recent additions available in Node 20+). Target remains ES2022 for
// compatibility with the lowest CI Node version.
//
// `moduleResolution: "bundler"` is used because Vite/Vitest consume these configs
// directly as native ESM, so Node-style resolution won't work for extensionless
// imports and package.json export maps.
{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "tailwind.config.ts",
    "postcss.config.js",
    "eslint.config.js",
    "tests/e2e/**/*.ts"
  ]
}
