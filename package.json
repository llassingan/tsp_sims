{
  "name": "tsp-simulator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Animated simulator for the Traveling Salesman Problem",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 14022",
    "dev:api": "node server/api.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 14022",
    "start": "node server/start.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "prepare": "husky || true",
    "size": "node scripts/check-size.mjs",
    "knip": "knip",
    "ts-prune": "ts-prune"
  },
  "dependencies": {
    "comlink": "^4.4.0",
    "d3-force": "^3.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.47.0",
    "@types/d3-force": "^3.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "autoprefixer": "^10.4.0",
    "depcheck": "^1.4.7",
    "eslint": "^9.9.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.0",
    "jsdom": "^25.0.0",
    "knip": "^5.27.0",
    "lint-staged": "^15.2.0",
    "postcss": "^8.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "size-limit": "^11.1.0",
    "tailwindcss": "^3.4.0",
    "ts-prune": "^0.10.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html}": [
      "prettier --write"
    ]
  }
}
