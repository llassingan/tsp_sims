# pnpm configuration for the TSP Simulator POC.
# - enable-pre-post-scripts: needed so husky (git hooks manager) can install
#   its prepare script dependencies; without this, `pnpm install` skips lifecycle
#   scripts and husky hooks are never registered.
# - ignore-pnpm-ignored-builds: false ensures @size-limit (which has a build
#   step pnpm normally ignores) runs its postinstall compilation so `pnpm size`
#   works out of the box.
enable-pre-post-scripts=true
ignore-pnpm-ignored-builds=false
